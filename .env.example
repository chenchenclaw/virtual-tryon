# Database (docker-compose 默认配置)
DATABASE_URL="postgresql://tryon:tryon123@localhost:5432/virtual_tryon?schema=public"

# Redis (docker-compose 默认配置)
REDIS_URL="redis://localhost:6379"

# OpenAI - 语言模型（gpt-4o 等，用于服装识别、体型描述、质量自检）
# 这里我们采用小米的mimo-v2.5-pro
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_BASE_URL="https://your-language-proxy.com/v1"

# 生图模型（gpt-image-2/gpt-image-2pro）
OPENAI_IMAGE_API_KEY="sk-your-image-api-key"
OPENAI_IMAGE_BASE_URL="https://your-image-proxy.com/v1"
# gpt-image-2 支持 1k，gpt-image-2pro 支持 2k/4k
OPENAI_IMAGE_MODEL="gpt-image-2pro"

# Auth
JWT_SECRET="your-jwt-secret-change-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
